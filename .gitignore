# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Сборка портативной версии (PyInstaller): package.spec и build_dist.py в гите,
# а результат сборки - нет (сотни МБ, пересобирается из исходников).
/build/
/dist/
*.spec.log

# Логи
*.log

# Локальные настройки установки: прежде всего адрес сервера ИИ. Это свойство
# конкретной машины, а не проекта, и в общем config.yaml он неизбежно
# оказывался чьим-то личным. Образец - config.local.example.yaml, он в гите.
/analyzer_to_errors/config.local.yaml

# Результаты анализа и промежуточные данные (генерируются при каждом прогоне)
/analyzer_to_errors/output/
/analyzer_to_errors/data/manifest.json
/analyzer_to_errors/data/.doc_types.json

# Извлечённые данные по документам (папка на каждый входной документ)
/analyzer_to_errors/data/*/
!/analyzer_to_errors/data/base_files/
!/analyzer_to_errors/data/base_analysis_scripts/
!/analyzer_to_errors/data/your_helping_scripts_and_files/

# Пользовательские файлы на анализ - только сами файлы, не код; папка нужна
# в репозитории (иначе pipeline падает без неё), а содержимое - личные
# документы пользователя, их вообще не должно быть в гите
/analyzer_to_errors/data/base_files/*
!/analyzer_to_errors/data/base_files/.gitkeep

# Рабочая папка агента - служебная, наполняется на прогоне
/analyzer_to_errors/data/your_helping_scripts_and_files/*
!/analyzer_to_errors/data/your_helping_scripts_and_files/.gitkeep

# Сессии анализа: файлы пользователей, извлечённые данные и отчёты каждого
# прогона. Папка создаётся сервером сама, в репозитории ей делать нечего.
/analyzer_to_errors/sessions/

# Пользователи интерфейса (логины, пароли админов в открытом виде, токены).
# Свойство конкретной установки, а не проекта; создаётся сервером при первом
# запуске (учётка admin/admin), в гите ему делать нечего.
/analyzer_to_errors/users.json

# Обычные чаты с ИИ: активные и архивные диалоги пользователей плюс файлы,
# которые они в них прикладывали. Личные данные, создаётся сервером сам.
/chats/

# История анализов (прежний архив прогонов; сейчас архив - сама папка сессии)
/story/*/

# Входные документы, отложенные "на проверку" - личные файлы пользователя,
# не код проекта
/на проверку/

# Альбомы полных проектов (вход пользователя, сотни мегабайт)
/analyzer_to_errors/data/full_projects/
